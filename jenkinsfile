pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Repository checked out successfully!'
            }
        }

        stage('Test') {
            steps {
                echo 'Jenkins Pipeline is working!'
            }
        }

        stage('Build') {
            steps {
                sh 'echo "Running build..."'
                sh 'pwd'
                sh 'ls -la'
            }
        }
    }

    post {
        always {
            echo 'Pipeline execution completed.'
        }
        success {
            echo 'SUCCESS!'
        }
        failure {
            echo 'FAILED!'
        }
    }
}